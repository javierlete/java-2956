<persistence xmlns="http://java.sun.com/xml/ns/persistence"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://java.sun.com/xml/ns/persistence http://java.sun.com/xml/ns/persistence/persistence_2_0.xsd"
	version="2.0">

	<persistence-unit
		name="com.ipartek.formacion.ejemplos.ipartex.entidades">
		<class>com.ipartek.formacion.ejemplos.ipartex.entidades.Usuario</class>
		<class>com.ipartek.formacion.ejemplos.ipartex.entidades.Mensaje</class>

		<properties>
			<!-- Database connection settings -->
			<property name="jakarta.persistence.jdbc.url"
				value="jdbc:sqlite:ipartex-jpa.db" />
			<property name="jakarta.persistence.jdbc.user" value="" />
			<property name="jakarta.persistence.jdbc.password" value="" />
			<property name="jakarta.persistence.jdbc.driver" value="org.sqlite.JDBC" />

			<!-- Automatically export the schema -->
			<property
				name="jakarta.persistence.schema-generation.database.action"
				value="create-drop" />

			<!-- Echo all executed SQL to console -->
			<property name="hibernate.show_sql" value="true" />
			<property name="hibernate.format_sql" value="false" />
			<property name="hibernate.highlight_sql" value="false" />
		</properties>

	</persistence-unit>

</persistence>